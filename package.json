{
    "name": "brayns-viewer",
    "version": "0.1.0",
    "private": false,
    "homepage": "./",
    "sideEffects": [
        "*.css"
    ],
    "dependencies": {
        "@math.gl/core": "^3.5.6",
        "hammerjs": "^2.0.8",
        "json5": "^2.2.0",
        "react": "^17.0.2",
        "react-dom": "^17.0.2",
        "react-simple-code-editor": "^0.11.0",
        "three": "^0.133.1"
    },
    "scripts": {
        "start": "webpack serve --mode development",
        "build": "webpack --mode production",
        "lint": "eslint -c .eslintrc.js 'src/**/*.ts' 'src/**/*.tsx'",
        "test": "jest --testTimeout 10000 --runInBand --detectOpenHandles --forceExit",
        "test:watch": "jest --watch",
        "docker:build": "docker build -t bbpgitlab.epfl.ch:5050/viz/brayns/brayns-viewer:latest .",
        "docker:push": "docker login bbpgitlab.epfl.ch:5050 && docker image push bbpgitlab.epfl.ch:5050/viz/brayns/brayns-viewer:latest",
        "k8s:dashboard": "kubectl auth-proxy -n kubernetes-dashboard https://kubernetes-dashboard.svc"
    },
    "devDependencies": {
        "@babel/preset-typescript": "^7.15.0",
        "@types/hammerjs": "^2.0.40",
        "@types/jest": "^27.0.2",
        "@types/math3d": "^0.2.3",
        "@types/react": "^17.0.28",
        "@types/react-dom": "^17.0.9",
        "@types/react-test-renderer": "^17.0.1",
        "@types/three": "^0.133.0",
        "@typescript-eslint/eslint-plugin": "^5.0.0",
        "@typescript-eslint/eslint-plugin-tslint": "^5.0.0",
        "@typescript-eslint/parser": "^5.0.0",
        "babel-eslint": "^10.1.0",
        "babel-jest": "^27.2.5",
        "clean-webpack-plugin": "^4.0.0",
        "copy-webpack-plugin": "^9.0.1",
        "css-loader": "^6.4.0",
        "eslint": "^7.23.0",
        "eslint-config-prettier": "^8.3.0",
        "eslint-config-react-app": "^6.0.0",
        "eslint-plugin-flowtype": "^6.1.0",
        "eslint-plugin-import": "^2.25.1",
        "eslint-plugin-jsdoc": "^36.1.1",
        "eslint-plugin-jsx-a11y": "^6.4.1",
        "eslint-plugin-no-null": "^1.0.2",
        "eslint-plugin-prefer-arrow": "^1.2.3",
        "eslint-plugin-react": "^7.26.1",
        "eslint-plugin-react-hooks": "^4.2.0",
        "eslint-plugin-unicorn": "^37.0.1",
        "file-loader": "^6.2.0",
        "html-webpack-plugin": "^5.3.2",
        "htmlparser2": "^7.1.2",
        "identity-obj-proxy": "^3.0.0",
        "jest": "^27.3.1",
        "jest-websocket-mock": "^2.2.1",
        "mock-socket": "^9.0.5",
        "raw-loader": "^4.0.2",
        "react-test-renderer": "^17.0.2",
        "style-loader": "^3.3.0",
        "ts-jest": "^27.0.5",
        "ts-loader": "^9.2.6",
        "ts-node": "^10.3.0",
        "typescript": "^4.4.3",
        "url-loader": "^4.1.1",
        "webpack": "^5.58.1",
        "webpack-cli": "^4.9.0",
        "webpack-dev-server": "^4.3.1",
        "yaml-loader": "^0.6.0"
    },
    "jest": {
        "testEnvironment": "jsdom",
        "moduleFileExtensions": [
            "tsx",
            "ts",
            "js",
            "jsx",
            "wasm"
        ],
        "transform": {
            "^.+\\.tsx?$": "ts-jest"
        },
        "testMatch": [
            "**/*.(test|spec).(ts|tsx)"
        ],
        "globals": {
            "ts-jest": {
                "babelConfig": true,
                "tsconfig": "tsconfig.json"
            }
        },
        "moduleNameMapper": {
            "^@/contract/(.*)$": "<rootDir>/src/contract/$1",
            "^@/mock/(.*)$": "<rootDir>/src/mock/$1",
            "^@/tool/(.*)$": "<rootDir>/src/tool/$1",
            "^@/ui/(.*)$": "<rootDir>/src/ui/$1",
            "^@/view/(.*)$": "<rootDir>/src/view/$1",
            "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/__mocks__/mocks.js",
            "\\.(css|less)$": "<rootDir>/__mocks__/mocks.js"
        },
        "verbose": true,
        "collectCoverage": true,
        "coverageReporters": [
            "lcov"
        ],
        "coverageDirectory": "test-coverage",
        "coverageThreshold": {
            "global": {
                "branches": 0,
                "functions": 0,
                "lines": 0,
                "statements": 0
            }
        }
    }
}
